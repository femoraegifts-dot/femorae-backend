<!DOCTYPE html>
<html>
<head>
  <title>School View</title>
</head>
<body>

<h1><%= school.name %></h1>

<p>Total Students: <%= students.length %></p>

<p>
<a href="/admin/delete-school/<%= school.id %>"
onclick="return confirm('Delete full school?')"
style="color:red;">
Delete School
</a>
</p>

<hr>

<table border="1" cellpadding="8">
<tr>
<th>ID</th>
<th>Name</th>
<th>Code</th>
<th>Status</th>
</tr>

<% students.forEach(s => { %>
<tr>
<td><%= s.id %></td>
<td><%= s.name || '' %></td>
<td><%= s.student_code || '' %></td>
<td><%= s.approved_status || '' %></td>
</tr>
<% }) %>

</table>

</body>
</html>