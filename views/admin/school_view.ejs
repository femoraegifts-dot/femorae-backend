<!DOCTYPE html>
<html>
<head>
  <title>School View</title>
  <link rel="stylesheet" href="/admin.css">
</head>
<body>

<%- include('../partials/header') %>

<div style="display:flex;">
  <%- include('../partials/sidebar') %>

  <div style="padding:20px; flex:1;">

    <h2><%= school.name %></h2>

    <p>
      Total Students:
      <strong><%= students.length %></strong>
    </p>

    <p>
      <a href="/admin/delete-school/<%= school.id %>"
         onclick="return confirm('Delete full school data?')"
         style="color:red; font-weight:bold;">
         Delete School
      </a>
    </p>

    <hr>

    <!-- =========================================
         CLASS MANAGEMENT
    ========================================== -->

    <h3>Class Management</h3>

    <div style="display:flex; gap:40px; margin-bottom:30px;">

     //
      <!-- ADD DIVISION -->
      <form method="POST"
            action="/admin/school/<%= school.id %>/add-division">

        <h4>Add Division</h4>

        <select name="class_id"
                required
                style="padding:8px;">

          <%
          const uniqueClasses = [];

          structure.forEach(row => {
            if(
              !uniqueClasses.find(
                c => c.class_id == row.class_id
              )
            ){
              uniqueClasses.push(row);
            }
          });
          %>

          <% uniqueClasses.forEach(c => { %>

            <option value="<%= c.class_id %>">
              <%= c.class_name %>
            </option>

          <% }) %>

        </select>

        <input type="text"
               name="division_name"
               placeholder="Division"
               required
               style="padding:8px;">

        <button type="submit"
                style="padding:8px 12px;">
          Add Division
        </button>

      </form>

    </div>

    <!-- =========================================
         SCHOOL STRUCTURE
    ========================================== -->

    <h3>School Structure</h3>

    <table border="1"
           cellpadding="8"
           cellspacing="0"
           width="100%"
           style="margin-bottom:30px;">

      <thead>
        <tr>
          <th>Class</th>
          <th>Division</th>
          <th>Total Students</th>
        </tr>
      </thead>

      <tbody>

        <% structure.forEach(row => { %>

          <tr>

            <td>
              <%= row.class_name %>
            </td>

            <td>
              <%= row.division_name || '-' %>
            </td>

            <td>
              <%= row.total_students %>
            </td>

          </tr>

        <% }) %>

      </tbody>

    </table>

    <!-- =========================================
         STUDENTS TABLE
    ========================================== -->

    <h3>Students</h3>

    <table border="1"
           cellpadding="8"
           cellspacing="0"
           width="100%">

      <thead>
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Student Code</th>
          <th>Status</th>
          <th>Action</th>
        </tr>
      </thead>

      <tbody>

        <% students.forEach(student => { %>

          <tr>

            <td>
              <%= student.id %>
            </td>

            <td>
              <%= student.name || '' %>
            </td>

            <td>
              <%= student.student_code || '' %>
            </td>

            <td>

              <% if(student.approved_status === 'approved'){ %>

                <span style="color:green; font-weight:bold;">
                  Approved
                </span>

              <% } else { %>

                <span style="color:orange; font-weight:bold;">
                  Pending
                </span>

              <% } %>

            </td>

            <td>

              <% if(student.approved_status === 'approved'){ %>

                <a href="/admin/unapprove/<%= student.id %>"
                   style="color:orange; font-weight:bold;"
                   onclick="return confirm('Change approved status to pending?')">

                   Make NULL

                </a>

              <% } else { %>

                -

              <% } %>

            </td>

          </tr>

        <% }) %>

      </tbody>

    </table>

  </div>
</div>

</body>
</html>