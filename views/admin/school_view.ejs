<!DOCTYPE html>
<html>
<head>
  <title>School View</title>
  <link rel="stylesheet" href="/admin.css">
</head>
<body>

<%- include('../partials/header') %>

<div style="display:flex;">
  <%- include('../partials/sidebar') %>

  <div style="padding:20px; flex:1;">

    <h2><%= school.name %></h2>

    <p>Total Students: <%= students.length %></p>

    <p>
      <a href="/admin/delete-school/<%= school.id %>"
         onclick="return confirm('Delete full school data?')"
         style="color:red; font-weight:bold;">
         Delete School
      </a>
    </p>

    <hr>

    <table border="1" cellpadding="8" cellspacing="0" width="100%">
      <thead>
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Student Code</th>
          <th>Status</th>
          <th>Action</th>
        </tr>
      </thead>

      <tbody>
        <% students.forEach(student => { %>
          <tr>
            <td><%= student.id %></td>

            <td><%= student.name || '' %></td>

            <td><%= student.student_code || '' %></td>

            <td>
              <%= student.approved_status || NULL %>
            </td>

            <td>

              <% if(student.approved_status === 'approved'){ %>

                <a href="/admin/unapprove/<%= student.id %>"
                   style="color:orange; font-weight:bold;"
                   onclick="return confirm('Change approved status to pending?')">
                   Make NULL
                </a>

              <% } else { %>

                -

              <% } %>

            </td>
          </tr>
        <% }) %>
      </tbody>

    </table>

  </div>
</div>

</body>
</html>