<!DOCTYPE html>
<link rel="stylesheet" href="/admin.css">
<h2>Export Students</h2>

<form method="GET" action="/students/export/excel">

  <!-- SCHOOL -->
  <label>School:</label>
  <select id="school" name="school_id" required>
    <option value="">Select School</option>

    <% if (schools && schools.length > 0) { %>
      <% schools.forEach(s => { %>
        <option value="<%= s.id %>"><%= s.name %></option>
      <% }) %>
    <% } else { %>
      <option>No schools found</option>
    <% } %>

  </select>

  <br/><br/>

  <!-- CLASS -->
  <label>Class:</label>
  <select id="class" name="class_id" required>
    <option value="">Select Class</option>
  </select>

  <br/><br/>

  <!-- DIVISION -->
  <label>Division:</label>
  <select id="division" name="division_id" required>
    <option value="">Select Division</option>
  </select>

  <br/><br/>

  <button type="submit">
    ⬇ Download Excel
  </button>

</form>

<script>
document.getElementById("school").addEventListener("change", async function () {
  const schoolId = this.value;

  const classDropdown = document.getElementById("class");
  const divisionDropdown = document.getElementById("division");

  // Reset
  classDropdown.innerHTML = '<option value="">Select Class</option>';
  divisionDropdown.innerHTML = '<option value="">Select Division</option>';

  if (!schoolId) return;

  try {
    const res = await fetch(`/admin/api/classes/${schoolId}`);
    const data = await res.json();

    console.log("Classes:", data);

    data.forEach(c => {
      const option = document.createElement("option");
      option.value = c.id;
      option.textContent = c.class_name;
      classDropdown.appendChild(option);
    });

  } catch (err) {
    console.error("Class load error:", err);
  }
});


document.getElementById("class").addEventListener("change", async function () {
  const classId = this.value;

  const divisionDropdown = document.getElementById("division");
  divisionDropdown.innerHTML = '<option value="">Select Division</option>';

  if (!classId) return;

  try {
    const res = await fetch(`/admin/api/divisions/${classId}`);
    const data = await res.json();

    console.log("Divisions:", data);

    data.forEach(d => {
      const option = document.createElement("option");
      option.value = d.id;
      option.textContent = d.division_name;
      divisionDropdown.appendChild(option);
    });

  } catch (err) {
    console.error("Division load error:", err);
  }
});
</script>