<script>
document.getElementById("school").addEventListener("change", async function () {
  const schoolId = this.value;

  const classDropdown = document.getElementById("class");
  const divisionDropdown = document.getElementById("division");

  // Reset dropdowns
  classDropdown.innerHTML = '<option value="">Select Class</option>';
  divisionDropdown.innerHTML = '<option value="">Select Division</option>';

  if (!schoolId) return;

  try {
    const res = await fetch(`/admin/api/classes/${schoolId}`);
    const data = await res.json();

    data.forEach(c => {
      const option = document.createElement("option");
      option.value = c.id;               // ✅ ID
      option.textContent = c.class_name; // ✅ Name
      classDropdown.appendChild(option);
    });

  } catch (err) {
    console.error("Class load error:", err);
  }
});


document.getElementById("class").addEventListener("change", async function () {
  const classId = this.value;

  const divisionDropdown = document.getElementById("division");
  divisionDropdown.innerHTML = '<option value="">Select Division</option>';

  if (!classId) return;

  try {
    const res = await fetch(`/admin/api/divisions/${classId}`);
    const data = await res.json();

    data.forEach(d => {
      const option = document.createElement("option");
      option.value = d.id;                   // ✅ ID
      option.textContent = d.division_name;  // ✅ A/B/C
      divisionDropdown.appendChild(option);
    });

  } catch (err) {
    console.error("Division load error:", err);
  }
});
</script>